    function p2damage(obj) {
        p2.hittable = false
        if (p2.lifes <= 1 && p2.alive) {
            p2die(obj)
            p2.alive = false
        }
        p2.lifes -= 1
        repeat(0.15, 8, () => {
            p2.opacity = p2.opacity === 0.1 ? 1 : 0.1;
        });
        wait(1.2, () => {
            p2.hittable = true
        });
    }